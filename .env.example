# -------------------------------------------------------
# Allgemeine Server-Einstellungen
# -------------------------------------------------------
HTTP_PORT=3001
DATABASE=./database.sqlite3
DB_LIMIT=500
DB_LIMIT_LOG=100000
SOUNDPATH=/public/media/
MEDIAPATH=/media/
UUID_NAMESPACE=59cc72ec-4ff5-499d-81e2-ec49c1d01252
TIME_TO_DELETE_WAIP=30
DEFAULT_TIME_FOR_STANDBY=15
SYSTEM_CLEANUP_TIME=10000

# Standard-Admin / Standard-API-Nutzer (nur beim ersten Start verwendet)
DEFAULT_USER=me
DEFAULT_PASS=CHANGE_ME
DEFAULT_API_USER=apiuser
DEFAULT_API_PASS=CHANGE_ME
DEFAULT_USER_IP=127.0.0.1

# Sicherheit
SALT_ROUNDS=10
SESSION_SECRET=CHANGE_ME_long_random_string
JWT_SECRET=CHANGE_ME_long_random_string
SESSION_COOKIE_MAX_AGE=60000

# Regex fuer Zertifikats-Authentifizierung
AUTH_REGEX=(\d+)[.\-](\d+)[.\-](\w+)
RIGHTS_REGEX=\.(\d+)[.-]

# -------------------------------------------------------
# Entwicklungs-Einstellungen
# -------------------------------------------------------
DEV_LOG=false
DEV_SQLITE=false

# -------------------------------------------------------
# Erscheinung / Oeffentliche Einstellungen
# -------------------------------------------------------
PUBLIC_URL=https://your-domain.example.com
APP_NAME=Wachalarm IP-Web
APP_INFO=
COMPANY=Ihr Firmenname

# Karte: "tile" fuer Tile-Server, "wms" fuer WMS-Server (mit Tile-Server als Fallback)
MAP_SERVICE_TYPE=tile
MAP_TILE_URL=https://{s}.tile.openstreetmap.de/{z}/{x}/{y}.png
MAP_WMS_URL=
MAP_WMS_LAYERS=OSM-WMS
MAP_WMS_FORMAT=image/png
MAP_WMS_TRANSPARENT=true
MAP_WMS_VERSION=1.1.1

# Impressum / Datenschutz (externes Impressum / Datenschutz aktivieren)
EXT_IMPRINT=false
URL_IMPRINT=https://your-domain.example.com/impressum
EXT_PRIVACY=false
URL_PRIVACY=https://your-domain.example.com/datenschutz

SHOW_LOGIN=true

# -------------------------------------------------------
# OSRM Routing (Routen von Wachen zum Einsatzort)
# -------------------------------------------------------
# OSRM aktivieren (true/false)
OSRM_ENABLED=false
# Hostname/IP des OSRM-Containers
OSRM_HOST=localhost
# HTTP-Port des OSRM-Containers
OSRM_PORT=5000

# -------------------------------------------------------
# Text-to-Speech (TTS)
# -------------------------------------------------------
# Provider: "local" (plattformspezifisch, Standard) oder "piper" (Piper-Docker)
TTS_PROVIDER=local

# Piper-Einstellungen (nur relevant wenn TTS_PROVIDER=piper)
# Hostname/IP des Piper-Containers
PIPER_HOST=localhost
# Wyoming-Protokoll-Port des Piper-Containers
PIPER_PORT=10200
# Stimme im Piper-Format (Modell muss im Container unter /models verfügbar sein)
PIPER_VOICE=de_DE-thorsten_emotional-medium
